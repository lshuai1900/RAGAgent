# Ragent-Py 环境变量样例
# 复制为 .env 并填入真实值；.env 不入 git

# 应用
RAGENT__APP__HOST=0.0.0.0
RAGENT__APP__PORT=8000

# PostgreSQL
RAGENT__DB__URL=postgresql+asyncpg://ragent:ragent@localhost:5432/ragent

# Milvus
RAGENT__MILVUS__URI=http://localhost:19530

# LLM (qwen / OpenAI-compatible)
QWEN_API_KEY=your-qwen-api-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# Embedding (OpenAI-compatible)
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=10
EMBEDDING_TIMEOUT=60
EMBEDDING_SEND_DIMENSIONS=false

# 其他供应商示例（按需启用）
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
